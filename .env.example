# OpenWA-Go Environment Configuration
# Copy to .env and customize

# Core
API_PORT=2785
LOG_LEVEL=info
DOMAIN=localhost

# Engine (always whatsmeow)
ENGINE_TYPE=whatsmeow
BAILEYS_AUTH_DIR=./data/whatsmeow
SYNC_FULL_HISTORY=false

# Database
DATABASE_TYPE=sqlite
DATABASE_NAME=./data/openwa.sqlite
MAIN_DATABASE_NAME=./data/main.sqlite

# For PostgreSQL:
# DATABASE_TYPE=postgres
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=openwa
# DATABASE_USERNAME=openwa
# DATABASE_PASSWORD=change-me

# API Security
API_MASTER_KEY=
CORS_ORIGINS=*

# Session
AUTO_START_SESSIONS=false
MAX_CONCURRENT_SESSIONS=0

# Webhook
WEBHOOK_TIMEOUT=10000
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY=5000

# Media
MEDIA_DOWNLOAD_ENABLED=true
MEDIA_DOWNLOAD_MAX_BYTES=52428800

# Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./data/media

# Rate Limit
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MEDIUM_TTL=60000
RATE_LIMIT_MEDIUM_LIMIT=100

# Dashboard
SERVE_DASHBOARD=true
